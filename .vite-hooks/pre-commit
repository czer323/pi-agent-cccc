#!/usr/bin/env sh
# Branch protection: block direct commits to main
branch=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ "$branch" = "main" ]; then
  echo "ERROR: Direct commits to main are not allowed."
  echo "Create a feature branch first: git checkout -b <type>/<short-name>"
  exit 1
fi

# VP staged hook (format + lint + type-check on staged files)
vp staged
