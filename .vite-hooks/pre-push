#!/usr/bin/env sh
# Branch protection: block direct pushes to main
branch=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ "$branch" = "main" ]; then
  echo "ERROR: Direct pushes to main are not allowed."
  echo "Create a feature branch, push it, and open a PR."
  exit 1
fi

# Verify all tests pass before pushing
vp check || { echo "ERROR: vp check failed. Fix errors before pushing."; exit 1; }
vp test || { echo "ERROR: vp test failed. Fix failures before pushing."; exit 1; }
